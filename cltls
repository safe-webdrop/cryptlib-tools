def convert_chunked( data ):
     # data must be bytearray type
     
     Clear = bytearray()
     start = end = 0
     i = 0
     while i < (len(data) -1 ) :
          if (data[i] == 13) and (data[i+1] == 10) :
               end = i
               # length information found
	       # compute the length of the following chunk of bytes
               try:
                    Length = data[start:end].decode()
                    linelen = int(Length, 16)
               except:
                    linelen = 0
               pos = end + 2
               if linelen :
                    for byte in data[pos:pos+linelen] :
                         Clear.append(byte)

               # skip '\r\n'
               i = pos+linelen
               start = i
          i += 1
     return Clear

