ERR_INVALID    = 5
ERR_DENY       = 6
ERR_CONNECT    = 7
ERR_REPLY      = 8
ERR_REQUEST    = 9
ERR_CORRUPT    = 10
ERR_INCOMPLETE = 11
ERR_NOTFOUND   = 12
ERR_UNKNOWN    = 13

Status         = 13



HOME = str(Path.home()) + "/.cryptlib/"


# path to trusted information about servers in the end-user's home directory.
CertPath          = HOME + "certs/"
